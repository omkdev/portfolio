# Client (Vite — prefix with VITE_)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
VITE_SENTRY_DSN=
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
VITE_HERO_VIDEO_URL=https://res.cloudinary.com/your-cloud-name/video/upload/q_auto,f_auto/your-video-id

# Server only (Vercel → Settings → Environment Variables — no VITE_ prefix)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
CONTACT_TO_EMAIL=your-email@gmail.com

UPSTASH_REDIS_REST_URL=your_upstash_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
